# Copy this file to .env and replace every <...> placeholder before deployment.
# Never commit real private keys to source control.

ALTO_RPC_URL=<RPC_URL>
ALTO_MIN_ENTITY_STAKE=1
ALTO_MIN_EXECUTOR_BALANCE=1000000000000000000
ALTO_MIN_ENTITY_UNSTAKE_DELAY=1
ALTO_BUNDLE_MODE=auto
ALTO_MIN_BUNDLE_INTERVAL=100
ALTO_MAX_BUNDLE_INTERVAL=1000
ALTO_MAX_BUNDLE_COUNT=5
ALTO_MAX_BLOCK_RANGE=2000
ALTO_PORT=3000
ALTO_EXECUTOR_PRIVATE_KEYS=<COMMA_SEPARATED_EXECUTOR_PRIVATE_KEYS>
ALTO_UTILITY_PRIVATE_KEY=<UTILITY_PRIVATE_KEY>

# Comma-separated ERC-4337 EntryPoint addresses supported by the target network.
# Find the canonical addresses for each EntryPoint version in the official releases:
# https://github.com/eth-infinitism/account-abstraction/releases
# Confirm that each address is deployed on your target network before starting Alto.
ALTO_ENTRYPOINTS=<COMMA_SEPARATED_ENTRYPOINT_ADDRESSES>

ALTO_DEPLOY_SIMULATIONS_CONTRACT=true
ALTO_ENABLE_DEBUG_ENDPOINTS=true
ALTO_SAFE_MODE=false
ALTO_MEMPOOL_MAX_PARALLEL_OPS=5
ALTO_MEMPOOL_MAX_QUEUED_OPS=5
ALTO_ENFORCE_UNIQUE_SENDERS_PER_BUNDLE=false
ALTO_RESUBMIT_STUCK_TIMEOUT=30000
ALTO_MAX_RESUBMITS=3
ALTO_SKIP_LOCAL_GAS_CALCULATIONS=true
ALTO_ENABLE_CORS=true
